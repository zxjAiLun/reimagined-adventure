Branch = 0
PrerequisiteIndex = 0
AttackSpeedMultiplier = 1.06

[sub_resource type="Resource" id="Passive_vigour"]
script = ExtResource("2_node")
NodeId = "vigour"
DisplayName = "Vigour"
Description = "+5 max HP"
