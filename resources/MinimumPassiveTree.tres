[gd_resource type="Resource" script_class="PassiveTreeResource" load_steps=5 format=3]

[ext_resource type="Script" path="res://scripts/PassiveTreeResource.cs" id="1_tree"]
[ext_resource type="Script" path="res://scripts/PassiveNodeResource.cs" id="2_node"]

[sub_resource type="Resource" id="Passive_sharpened_bolt"]
